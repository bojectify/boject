{
  "name": "@boject/react-reveal",
  "version": "0.0.1-rc.3",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@boject/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!**/*.tsbuildinfo"
  ],
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "vite": "^7.0.0"
  },
  "sideEffects": [
    "*.css"
  ],
  "nx": {
    "tags": [
      "scope:react-reveal"
    ],
    "targets": {
      "test-storybook": {
        "command": "vitest run --project storybook",
        "options": {
          "cwd": "{projectRoot}"
        },
        "cache": true,
        "inputs": [
          "{projectRoot}/src/**/*.stories.{ts,tsx}",
          "{projectRoot}/.storybook/**/*",
          "{projectRoot}/vite.config.ts"
        ]
      },
      "stylelint": {
        "command": "stylelint \"src/**/*.css\"",
        "options": {
          "cwd": "{projectRoot}"
        },
        "cache": true,
        "inputs": [
          "{projectRoot}/src/**/*.css",
          "{workspaceRoot}/.stylelintrc.json"
        ]
      },
      "build": {
        "command": "tsup",
        "options": {
          "cwd": "{projectRoot}"
        },
        "cache": true,
        "inputs": [
          "production",
          "^production"
        ],
        "outputs": [
          "{projectRoot}/dist"
        ]
      }
    }
  }
}
