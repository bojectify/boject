{
  "name": "@boject/react-store-async",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@boject/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!**/*.tsbuildinfo"
  ],
  "peerDependencies": {
    "react": ">=18.0.0",
    "@boject/react-store": ">=0.0.1"
  },
  "devDependencies": {
    "vite": "^7.0.0",
    "@boject/react-store": "workspace:*"
  },
  "sideEffects": false,
  "nx": {
    "tags": [
      "scope:react-store-async"
    ],
    "targets": {
      "build": {
        "command": "tsup",
        "options": {
          "cwd": "{projectRoot}"
        },
        "cache": true,
        "inputs": [
          "production",
          "^production"
        ],
        "outputs": [
          "{projectRoot}/dist"
        ]
      }
    }
  }
}
